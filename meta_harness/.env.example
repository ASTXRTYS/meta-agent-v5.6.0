LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=meta-agent
ANTHROPIC_API_KEY=your-anthropic-api-key
META_AGENT_MODEL=anthropic:claude-opus-4-6
META_AGENT_MODEL_PROVIDER=anthropic  # DEPRECATED: use META_AGENT_MODEL (provider:model_name format) instead
META_AGENT_MODEL_NAME=claude-opus-4-6  # DEPRECATED: use META_AGENT_MODEL (provider:model_name format) instead
META_AGENT_MAX_REFLECTION_PASSES=3
# Ensure traces complete before process exit (required for experiment runs)
LANGCHAIN_CALLBACKS_BACKGROUND=false

# Console debug logging is enabled in server.py via set_debug(True)
# To disable console logging, comment out the set_debug(True) line in meta_agent/server.py
